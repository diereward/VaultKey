<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        app:backgroundTint="@color/background"
        app:liftOnScroll="false"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:layout_marginEnd="12dp"
            app:title="@string/title_generator"
            app:titleTextColor="@color/on_surface" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/adaptive_padding"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/brand_alpha"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvGeneratedPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.3"
                        android:minHeight="56dp"
                        android:text="@string/generator_placeholder"
                        android:textColor="@color/brand"
                        android:textSize="22sp"
                        android:fontFamily="monospace" />

                    <LinearLayout
                        android:id="@+id/strengthContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical">

                        <include
                            layout="@layout/view_strength_indicator"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRefresh"
                            android:layout_width="56dp"
                            android:layout_height="48dp"
                            android:layout_marginEnd="8dp"
                            android:contentDescription="@string/generator_action_refresh"
                            android:paddingStart="0dp"
                            android:paddingEnd="0dp"
                            android:text=""
                            android:textColor="@color/brand"
                            app:backgroundTint="@color/brand_alpha"
                            app:cornerRadius="24dp"
                            app:icon="@drawable/ic_refresh"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:iconSize="22dp"
                            app:iconTint="@color/brand" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCopy"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="@string/generator_copy"
                            android:textColor="@color/white"
                            app:backgroundTint="@color/brand"
                            app:cornerRadius="24dp"
                            app:icon="@drawable/ic_copy"
                            app:iconTint="@color/white" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="4dp"
                        android:background="@color/brand_stroke" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveAsPassword"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="4dp"
                        android:text="@string/generator_save_as_password"
                        android:textColor="@color/brand"
                        app:cornerRadius="24dp"
                        app:icon="@drawable/ic_add"
                        app:iconTint="@color/brand"
                        app:strokeColor="@color/brand_stroke" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/surface_container_high"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/generator_section_params"
                        android:textColor="@color/on_surface"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/generator_length_label"
                            android:textColor="@color/on_surface"
                            android:textSize="14sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipLength"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="16"
                            android:textColor="@color/brand"
                            android:textStyle="bold"
                            app:chipBackgroundColor="@android:color/transparent"
                            app:chipStrokeColor="@color/brand"
                            app:chipStrokeWidth="1.5dp"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/seekLength"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:max="32"
                        android:min="6"
                        android:progress="16"
                        android:progressTint="@color/brand"
                        android:thumbTint="@color/brand" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:scrollbars="none">

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chipGroupPresets"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:singleSelection="true">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip8"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="8"
                                android:textColor="@color/selector_chip_text"
                                app:chipBackgroundColor="@color/selector_chip_bg"
                                app:checkedIconVisible="false" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip12"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12"
                                android:textColor="@color/selector_chip_text"
                                app:chipBackgroundColor="@color/selector_chip_bg"
                                app:checkedIconVisible="false" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip16"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true"
                                android:text="16"
                                android:textColor="@color/selector_chip_text"
                                app:chipBackgroundColor="@color/selector_chip_bg"
                                app:checkedIconVisible="false" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip24"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="24"
                                android:textColor="@color/selector_chip_text"
                                app:chipBackgroundColor="@color/selector_chip_bg"
                                app:checkedIconVisible="false" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip32"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="32"
                                android:textColor="@color/selector_chip_text"
                                app:chipBackgroundColor="@color/selector_chip_bg"
                                app:checkedIconVisible="false" />
                        </com.google.android.material.chip.ChipGroup>
                    </HorizontalScrollView>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="@color/outline_variant" />

                    <include
                        android:id="@+id/toggleLower"
                        layout="@layout/view_toggle_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <include
                        android:id="@+id/toggleUpper"
                        layout="@layout/view_toggle_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <include
                        android:id="@+id/toggleDigits"
                        layout="@layout/view_toggle_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <include
                        android:id="@+id/toggleSymbols"
                        layout="@layout/view_toggle_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />



                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="32dp" />
        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>